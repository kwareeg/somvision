---
interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { label, title, description, centered = false } = Astro.props;
---

<div class:list={["fade-up", { "text-center": centered }]}>
  {label && (
    <p class="uppercase text-xs font-bold tracking-widest text-blue mb-3">
      {label}
    </p>
  )}
  <h2 class="text-3xl md:text-4xl font-bold text-navy">
    {title}
  </h2>
  {description && (
    <p class:list={[
      "text-lg text-slate-600 mt-4",
      { "max-w-2xl mx-auto": centered },
      { "max-w-none": !centered },
    ]}>
      {description}
    </p>
  )}
</div>
