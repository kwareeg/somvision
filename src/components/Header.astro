---
const navItems = [
  { label: "Home", href: "/" },
  {
    label: "About",
    href: "/about",
    children: [
      { label: "Who We Are", href: "/about#who-we-are" },
      { label: "Vision & Mission", href: "/about#vision-mission" },
      { label: "Core Values", href: "/about#core-values" },
      { label: "Leadership & Team", href: "/about#leadership" },
      { label: "Our Approach", href: "/about#approach" },
    ],
  },
  {
    label: "Services",
    href: "/services",
    children: [
      { label: "Strategy & Advisory", href: "/services#strategy" },
      { label: "Governance & Institutional Strengthening", href: "/services#governance" },
      { label: "Project Management, MEL & Compliance", href: "/services#project-management" },
      { label: "Digital & IT Consulting", href: "/services#digital" },
      { label: "HR & Capacity Development", href: "/services#hr" },
    ],
  },
  {
    label: "Sectors",
    href: "/sectors",
    children: [
      { label: "Labor, Employment & Social Protection", href: "/sectors#labor" },
      { label: "Livestock, Veterinary & One Health", href: "/sectors#livestock" },
      { label: "Governance & Public Sector Reform", href: "/sectors#governance" },
      { label: "Development Programs & Donor Support", href: "/sectors#development" },
    ],
  },
  {
    label: "Our Work",
    href: "/work",
    children: [
      { label: "Featured Projects", href: "/work#projects" },
      { label: "Clients & Partners", href: "/work#clients" },
      { label: "Results & Impact", href: "/work#impact" },
    ],
  },
{ label: "Contact", href: "/contact" },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-0 text-xl font-bold">
        <span class="text-navy">SOM</span><span class="text-blue">VISION</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium text-slate-700 hover:text-blue transition-colors"
            >
              {item.label}
              {item.children && (
                <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="w-64 bg-white border border-slate-200 rounded-lg shadow-lg py-2">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-slate-600 hover:text-blue hover:bg-slate-50 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <a
        href="/contact"
        class="hidden lg:inline-flex bg-blue text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-dark transition-colors"
      >
        Contact Us
      </a>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="lg:hidden p-2 text-slate-700 hover:text-navy"
        id="mobile-menu-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <div class="w-5 h-0.5 bg-current mb-1"></div>
        <div class="w-5 h-0.5 bg-current mb-1"></div>
        <div class="w-5 h-0.5 bg-current"></div>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-slate-200">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-4 space-y-1" aria-label="Mobile navigation">
      {navItems.map((item) => (
        <div>
          {item.children ? (
            <div class="mobile-dropdown">
              <button
                type="button"
                class="mobile-dropdown-toggle flex items-center justify-between w-full px-3 py-2 text-sm font-medium text-slate-700 hover:text-blue transition-colors"
              >
                <span>{item.label}</span>
                <svg class="w-4 h-4 opacity-50 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="mobile-dropdown-panel hidden pl-4 pb-2 space-y-1">
                <a
                  href={item.href}
                  class="block px-3 py-1.5 text-sm text-slate-600 hover:text-blue transition-colors"
                >
                  Overview
                </a>
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-3 py-1.5 text-sm text-slate-600 hover:text-blue transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="block px-3 py-2 text-sm font-medium text-slate-700 hover:text-blue transition-colors"
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
      <div class="pt-3 border-t border-slate-100">
        <a
          href="/contact"
          class="block w-full text-center bg-blue text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!menu.classList.contains("hidden")));
    });
  }

  document.querySelectorAll(".mobile-dropdown-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const panel = btn.nextElementSibling;
      if (panel) {
        panel.classList.toggle("hidden");
        const chevron = btn.querySelector("svg");
        if (chevron) {
          chevron.classList.toggle("rotate-180");
        }
      }
    });
  });
</script>
