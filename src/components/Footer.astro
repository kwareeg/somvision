---
const aboutLinks = [
  { label: "Who We Are", href: "/about#who-we-are" },
  { label: "Vision & Mission", href: "/about#vision-mission" },
  { label: "Core Values", href: "/about#core-values" },
  { label: "Leadership & Team", href: "/about#leadership" },
];

const serviceLinks = [
  { label: "Strategy & Advisory", href: "/services#strategy" },
  { label: "Governance", href: "/services#governance" },
  { label: "Project Management", href: "/services#project-management" },
  { label: "Digital & IT", href: "/services#digital" },
];

const bottomLinks = [
  { label: "Terms of Use", href: "/terms" },
  { label: "Privacy Notice", href: "/privacy" },
  { label: "Ethics & Safeguarding", href: "/ethics" },
  { label: "Accessibility", href: "/accessibility" },
  { label: "Sitemap", href: "/sitemap" },
];
---

<footer class="bg-navy text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">
      <!-- Brand column (spans 2) -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-block text-2xl font-bold text-blue mb-4">SOMVISCON</a>
        <p class="text-slate-400 text-sm leading-relaxed max-w-sm">
          Advisory and implementation support for government, development partners, and institutions across Somalia.
        </p>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center mt-6 text-slate-400 hover:text-white transition-colors"
          aria-label="SOMVISCON on LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- About column -->
      <div>
        <h3 class="text-white text-sm font-semibold uppercase tracking-wider mb-4">About</h3>
        <ul class="space-y-2.5">
          {aboutLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="text-white text-sm font-semibold uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2.5">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-white text-sm font-semibold uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-2.5 text-sm text-slate-400">
          <li>Mogadishu, Somalia</li>
          <li>
            <a href="mailto:info@somviscon.com" class="hover:text-white transition-colors">
              info@somviscon.com
            </a>
          </li>
          <li>+252 (612657171)</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-xs text-slate-500">
          &copy; 2024 SOMVISCON. All rights reserved.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
          {bottomLinks.map((link) => (
            <a href={link.href} class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
