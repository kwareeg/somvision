---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative bg-navy overflow-hidden">
  <!-- Subtle radial gradient overlays -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute -top-1/4 -right-1/4 w-3/4 h-3/4 rounded-full"
      style="background: radial-gradient(circle, var(--color-teal) 0%, transparent 70%); opacity: 0.05;"
    ></div>
    <div
      class="absolute -bottom-1/4 -left-1/4 w-3/4 h-3/4 rounded-full"
      style="background: radial-gradient(circle, var(--color-blue) 0%, transparent 70%); opacity: 0.05;"
    ></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <h1 class="fade-up text-4xl md:text-5xl font-bold text-white">
      {title}
    </h1>
    {subtitle && (
      <p class="fade-up delay-1 text-lg text-slate-300 mt-4 max-w-2xl">
        {subtitle}
      </p>
    )}
  </div>
</section>
