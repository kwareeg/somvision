---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import CTABand from '../../components/CTABand.astro';
---

<Base title="Our Sectors | SOMVISCON" description="Sector depth aligned to Somalia's priorities across labor, livestock, governance, and development programs.">

  <PageHero
    title="Our Sectors"
    subtitle="Sector depth aligned to Somalia's priorities"
  />

  <!-- Intro -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <SectionIntro
        centered
        title="Sectoral Expertise for Somalia's Development"
        description="We deliver specialized advisory and implementation support across sectors central to Somalia's human capital development, employment generation, and productive livelihoods. Our focus reflects national priorities as outlined in the National Transformation Plan and the operational requirements of development partner programs."
      />
    </div>
  </section>

  <!-- Sector 1: Labor, Employment & Social Protection -->
  <section id="labor" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Left: Icon + Tags -->
        <div class="col-span-1 lg:col-span-2">
          <div class="w-20 h-20 rounded-2xl bg-teal/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a4 4 0 00-8 0v2" /><circle cx="12" cy="14" r="2" />
            </svg>
          </div>
          <div class="flex gap-2 flex-wrap mt-4">
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Labor Markets</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Employment</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Social Protection</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">TVET</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Youth</span>
          </div>
        </div>
        <!-- Right: Content -->
        <div class="col-span-1 lg:col-span-3">
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Labor, Employment & Social Protection</h2>
          <p class="text-lg text-slate-600 mt-3">SOMVISCON supports integrated labor, employment, social protection, and digital service delivery systems. We work to expand decent work opportunities, strengthen social inclusion, and improve access to services for vulnerable populations including youth, women, internally displaced persons, returnees, and persons with disabilities.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Labor market assessments and employment diagnostics</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Jobs and skills program design and implementation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Technical and vocational education and training (TVET) strategies</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Youth employment and apprenticeship programs</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Entrepreneurship programs and occupational standards</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Workforce planning and skills matching systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Design and strengthening of inclusive social protection systems</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sector 2: Livestock, Veterinary Services & One Health -->
  <section id="livestock" class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Left: Content (reversed on desktop) -->
        <div class="col-span-1 lg:col-span-3 order-2 lg:order-1">
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Livestock, Veterinary Services & One Health</h2>
          <p class="text-lg text-slate-600 mt-3">SOMVISCON brings cross-sectoral expertise to support Somalia's livestock economy, one of the country's largest sources of employment, exports, and household income. Our work aligns with labor, livelihoods, and public health objectives.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Institutional and policy support for veterinary and animal health services</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Capacity building for veterinary officers and paraprofessionals</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Advisory on livestock-based livelihoods and employment programs</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Disease surveillance, reporting systems, and field operations</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Integration of livestock health into One Health and social resilience frameworks</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Support to donor-funded livestock and veterinary programs</span>
            </li>
          </ul>
        </div>
        <!-- Right: Icon + Tags (reversed on desktop) -->
        <div class="col-span-1 lg:col-span-2 order-1 lg:order-2">
          <div class="w-20 h-20 rounded-2xl bg-teal/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
            </svg>
          </div>
          <div class="flex gap-2 flex-wrap mt-4">
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Livestock</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Veterinary</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">One Health</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Livelihoods</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sector 3: Governance & Public Sector Reform -->
  <section id="governance" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Left: Icon + Tags -->
        <div class="col-span-1 lg:col-span-2">
          <div class="w-20 h-20 rounded-2xl bg-teal/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6M9 9h.01M15 9h.01M9 13h.01M15 13h.01" />
            </svg>
          </div>
          <div class="flex gap-2 flex-wrap mt-4">
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Governance</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Public Sector</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Reform</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Accountability</span>
          </div>
        </div>
        <!-- Right: Content -->
        <div class="col-span-1 lg:col-span-3">
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Governance & Public Sector Reform</h2>
          <p class="text-lg text-slate-600 mt-3">SOMVISCON supports ministries and public institutions to strengthen governance systems, improve service delivery, and meet fiduciary and accountability standards required by development partners.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Institutional capacity assessments and reform roadmaps</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Policy and regulatory development</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Results-based management and performance systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Public sector coordination and inter-ministerial alignment</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Fiduciary and accountability standards implementation</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sector 4: Development Programs & Donor Support -->
  <section id="development" class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Left: Content (reversed on desktop) -->
        <div class="col-span-1 lg:col-span-3 order-2 lg:order-1">
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Development Programs & Donor Support</h2>
          <p class="text-lg text-slate-600 mt-3">We provide end-to-end project support aligned with operational policies and result frameworks. This covers project design, implementation, monitoring, evaluation, learning, and compliance advisory.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Project design and implementation support</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">MEL system development and management</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Results frameworks, indicators, and reporting</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Donor compliance and fiduciary advisory</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Safeguards and risk management</span>
            </li>
          </ul>
        </div>
        <!-- Right: Icon + Tags (reversed on desktop) -->
        <div class="col-span-1 lg:col-span-2 order-1 lg:order-2">
          <div class="w-20 h-20 rounded-2xl bg-teal/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
            </svg>
          </div>
          <div class="flex gap-2 flex-wrap mt-4">
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Development</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Donor Programs</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">MEL</span>
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">Compliance</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    title="Looking for sector-specific expertise?"
    description="Our teams bring deep sectoral knowledge to every engagement."
    primaryLabel="Discuss Your Needs"
    primaryHref="/contact"
    secondaryLabel="View Our Services"
    secondaryHref="/services"
  />

</Base>
