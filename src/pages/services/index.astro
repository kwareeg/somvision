---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import CTABand from '../../components/CTABand.astro';
---

<Base title="Our Services | SOMVISION" description="Comprehensive consulting services across strategy, governance, project management, digital solutions, and capacity development.">

  <PageHero
    title="Our Services"
    subtitle="Designed for implementation and accountability"
  />

  <!-- Intro -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <SectionIntro
        centered
        label="What Clients Receive"
        title="Comprehensive support across every engagement"
      />
      <div class="flex flex-wrap justify-center gap-4 mt-10">
        <span class="bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-sm text-slate-700 font-medium">Diagnostics and analysis</span>
        <span class="bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-sm text-slate-700 font-medium">Implementation-ready plans</span>
        <span class="bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-sm text-slate-700 font-medium">Tools and systems</span>
        <span class="bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-sm text-slate-700 font-medium">Capacity building</span>
        <span class="bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-sm text-slate-700 font-medium">Results frameworks and reporting</span>
      </div>
    </div>
  </section>

  <!-- Service 1: Strategy & Advisory -->
  <section id="strategy" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Icon -->
        <div>
          <div class="w-16 h-16 rounded-xl bg-blue/10 flex items-center justify-center mb-6 lg:mb-0">
            <svg class="w-8 h-8 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" /><line x1="12" y1="2" x2="12" y2="6" /><line x1="12" y1="18" x2="12" y2="22" /><line x1="2" y1="12" x2="6" y2="12" /><line x1="18" y1="12" x2="22" y2="12" />
            </svg>
          </div>
        </div>
        <!-- Content -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Strategy & Advisory</h2>
          <p class="text-lg text-slate-600 mt-3">Strategy development translated into actionable plans with clear priorities, governance, and KPIs.</p>
          <p class="text-slate-600 mt-4">We help institutions move from high-level goals to concrete, measurable strategies. Every plan is tied to delivery mechanisms, accountability frameworks, and realistic timelines.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Strategic planning and policy advice</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Institutional diagnostics</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Stakeholder engagement frameworks</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">KPI development and governance design</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Program theory of change</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 2: Governance & Institutional Strengthening -->
  <section id="governance" class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Content -->
        <div class="order-2 lg:order-1">
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Governance & Institutional Strengthening</h2>
          <p class="text-lg text-slate-600 mt-3">Support to improve institutional performance, coordination, and accountability systems.</p>
          <p class="text-slate-600 mt-4">SOMVISION supports ministries and public institutions to strengthen governance systems, improve service delivery, and meet fiduciary standards required by development partners.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Institutional capacity assessments</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Reform roadmaps and implementation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Policy and regulatory development</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Results-based management systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Public sector coordination</span>
            </li>
          </ul>
        </div>
        <!-- Icon -->
        <div class="order-1 lg:order-2">
          <div class="w-16 h-16 rounded-xl bg-blue/10 flex items-center justify-center mb-6 lg:mb-0">
            <svg class="w-8 h-8 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6M9 9h.01M15 9h.01M9 13h.01M15 13h.01" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 3: Project Management, MEL & Compliance -->
  <section id="project-management" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Icon -->
        <div>
          <div class="w-16 h-16 rounded-xl bg-blue/10 flex items-center justify-center mb-6 lg:mb-0">
            <svg class="w-8 h-8 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" /><rect x="9" y="3" width="6" height="4" rx="1" /><path d="M9 14l2 2 4-4" />
            </svg>
          </div>
        </div>
        <!-- Content -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Project Management, MEL & Compliance</h2>
          <p class="text-lg text-slate-600 mt-3">End-to-end delivery support including planning, reporting, evaluation, and compliance.</p>
          <p class="text-slate-600 mt-4">We provide project support aligned with operational policies and result frameworks, covering design, implementation, monitoring, evaluation, learning, and compliance advisory.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Project design and delivery support</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">MEL system development</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Results frameworks and indicators</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Donor reporting and compliance</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Fiduciary and safeguard advisory</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 4: Digital & IT Consulting -->
  <section id="digital" class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Content -->
        <div class="order-2 lg:order-1">
          <h2 class="text-2xl md:text-3xl font-bold text-navy">Digital & IT Consulting</h2>
          <p class="text-lg text-slate-600 mt-3">Design and implementation of digital service delivery systems, dashboards, and data platforms.</p>
          <p class="text-slate-600 mt-4">We support institutions to use technology for improved service delivery, data management, and decision-making. Our digital solutions are designed for sustainability and local capacity.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Digital service delivery platforms</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Management information systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Data dashboards and analytics</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Digital transformation strategy</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Technology capacity building</span>
            </li>
          </ul>
        </div>
        <!-- Icon -->
        <div class="order-1 lg:order-2">
          <div class="w-16 h-16 rounded-xl bg-blue/10 flex items-center justify-center mb-6 lg:mb-0">
            <svg class="w-8 h-8 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="2" y="3" width="20" height="14" rx="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 5: HR & Capacity Development -->
  <section id="hr" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Icon -->
        <div>
          <div class="w-16 h-16 rounded-xl bg-blue/10 flex items-center justify-center mb-6 lg:mb-0">
            <svg class="w-8 h-8 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" />
            </svg>
          </div>
        </div>
        <!-- Content -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-navy">HR & Capacity Development</h2>
          <p class="text-lg text-slate-600 mt-3">Workforce development, training, and organizational strengthening aligned to delivery needs.</p>
          <p class="text-slate-600 mt-4">We help organizations build the human capital needed for effective service delivery, combining institutional assessment with targeted training and mentoring.</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Workforce planning and development</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Training program design and delivery</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Organizational restructuring</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Performance management systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-slate-700">Knowledge transfer and mentoring</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    title="Need implementation support?"
    description="Tell us about your program and we will propose a tailored approach."
    primaryLabel="Request a Proposal"
    primaryHref="/contact"
    secondaryLabel="View Our Sectors"
    secondaryHref="/sectors"
  />

</Base>
