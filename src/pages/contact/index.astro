---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---

<Base title="Contact Us | SOMVISION" description="Get in touch with SOMVISION for consulting, technical assistance, and partnership inquiries.">

  <PageHero
    title="Contact Us"
    subtitle="Start a conversation"
  />

  <!-- Main Section -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Left Column: Contact Form -->
        <div class="lg:col-span-2 fade-up">
          <h2 class="text-2xl font-bold text-navy mb-6">Send Us an Inquiry</h2>

          <form id="contact-form" class="space-y-5">

            <!-- Row 1: Full Name, Organization -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="full-name" class="block text-sm font-medium text-navy mb-1.5">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="full-name"
                  name="full-name"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
              <div>
                <label for="organization" class="block text-sm font-medium text-navy mb-1.5">
                  Organization / Institution <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="organization"
                  name="organization"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
            </div>

            <!-- Row 2: Role, Email -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="role" class="block text-sm font-medium text-navy mb-1.5">
                  Role / Title
                </label>
                <input
                  type="text"
                  id="role"
                  name="role"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-navy mb-1.5">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
            </div>

            <!-- Row 3: Phone, Country -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block text-sm font-medium text-navy mb-1.5">
                  Phone / WhatsApp
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
              <div>
                <label for="country" class="block text-sm font-medium text-navy mb-1.5">
                  Country / Region
                </label>
                <input
                  type="text"
                  id="country"
                  name="country"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
            </div>

            <!-- Row 4: Area of Interest, Sector -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="area-of-interest" class="block text-sm font-medium text-navy mb-1.5">
                  Area of Interest
                </label>
                <select
                  id="area-of-interest"
                  name="area-of-interest"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                >
                  <option value="">Select an area</option>
                  <option value="Strategy & Advisory">Strategy and Advisory</option>
                  <option value="Governance & Institutional Strengthening">Governance and Institutional Strengthening</option>
                  <option value="Project Management MEL & Compliance">Project Management MEL and Compliance</option>
                  <option value="Digital & IT Consulting">Digital and IT Consulting</option>
                  <option value="HR & Capacity Development">HR and Capacity Development</option>
                  <option value="Multiple Areas">Multiple Areas</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div>
                <label for="sector" class="block text-sm font-medium text-navy mb-1.5">
                  Sector
                </label>
                <select
                  id="sector"
                  name="sector"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                >
                  <option value="">Select a sector</option>
                  <option value="Labor Employment & Social Protection">Labor Employment and Social Protection</option>
                  <option value="Livestock Veterinary & One Health">Livestock Veterinary and One Health</option>
                  <option value="Governance & Public Sector Reform">Governance and Public Sector Reform</option>
                  <option value="Development Programs & Donor Support">Development Programs and Donor Support</option>
                  <option value="Cross-Sector">Cross-Sector</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <!-- Row 5: Type of Request, Funding Source -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="request-type" class="block text-sm font-medium text-navy mb-1.5">
                  Type of Request
                </label>
                <select
                  id="request-type"
                  name="request-type"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                >
                  <option value="">Select a type</option>
                  <option value="Request for Proposal">Request for Proposal</option>
                  <option value="Technical Consultation">Technical Consultation</option>
                  <option value="Partnership Inquiry">Partnership Inquiry</option>
                  <option value="General Inquiry">General Inquiry</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div>
                <label for="funding-source" class="block text-sm font-medium text-navy mb-1.5">
                  Funding Source
                </label>
                <input
                  type="text"
                  id="funding-source"
                  name="funding-source"
                  placeholder="e.g., World Bank, USAID, EU, Self-funded"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                />
              </div>
            </div>

            <!-- Row 6: Timeline, Upload TOR -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="timeline" class="block text-sm font-medium text-navy mb-1.5">
                  Timeline
                </label>
                <select
                  id="timeline"
                  name="timeline"
                  class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white"
                >
                  <option value="">Select a timeline</option>
                  <option value="Immediate (within 1 month)">Immediate (within 1 month)</option>
                  <option value="Short-term (1-3 months)">Short-term (1 to 3 months)</option>
                  <option value="Medium-term (3-6 months)">Medium-term (3 to 6 months)</option>
                  <option value="Long-term (6+ months)">Long-term (6+ months)</option>
                  <option value="To be determined">To be determined</option>
                </select>
              </div>
              <div>
                <label for="tor-upload" class="block text-sm font-medium text-navy mb-1.5">
                  Upload Terms of Reference
                </label>
                <label
                  for="tor-upload"
                  class="flex items-center justify-center w-full px-4 py-3 border border-slate-300 border-dashed rounded-md text-sm text-slate-500 cursor-pointer hover:border-blue hover:text-blue transition bg-white"
                >
                  <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0l-4 4m4-4l4 4M4 20h16" />
                  </svg>
                  <span id="file-label">Choose file (PDF, DOC, DOCX, TXT)</span>
                </label>
                <input
                  type="file"
                  id="tor-upload"
                  name="tor-upload"
                  accept=".pdf,.doc,.docx,.txt"
                  class="hidden"
                />
              </div>
            </div>

            <!-- Row 7: Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-1.5">
                Message / Terms of Reference Summary <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Describe your needs, challenges, and timeline..."
                class="w-full px-4 py-3 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue focus:border-blue bg-white resize-y"
              ></textarea>
            </div>

            <!-- Row 8: Consent -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="consent"
                name="consent"
                required
                class="mt-1 h-4 w-4 rounded border-slate-300 text-blue focus:ring-blue"
              />
              <label for="consent" class="text-sm text-slate-600">
                I consent to SOMVISION collecting and processing this information to respond to my inquiry. Data will be handled per our Privacy Notice.
              </label>
            </div>

            <!-- Submit -->
            <div>
              <button
                type="submit"
                class="w-full md:w-auto bg-blue text-white px-8 py-3 rounded-md font-medium hover:bg-blue-dark transition text-sm cursor-pointer"
              >
                Submit Inquiry
              </button>
            </div>
          </form>

          <p class="text-xs text-slate-500 mt-4">
            All inquiries are treated confidentially. We typically respond within 2 to 3 business days.
          </p>

          <!-- Success Message -->
          <div id="success-message" class="hidden bg-teal/10 border border-teal rounded-lg p-6 text-center">
            <h3 class="text-lg font-semibold text-navy">Thank you</h3>
            <p class="text-sm text-slate-600 mt-2">We have received your inquiry and will respond within 2 to 3 business days.</p>
          </div>
        </div>

        <!-- Right Column: Contact Info Sidebar -->
        <div class="lg:col-span-1 fade-up">
          <div class="lg:sticky lg:top-24 space-y-6">

            <!-- Contact Info Card -->
            <div class="bg-slate-50 rounded-lg p-6 border border-slate-200">
              <h3 class="font-semibold text-navy mb-6">Get in Touch</h3>
              <div class="space-y-5">
                <!-- Location -->
                <div class="flex gap-3 items-start">
                  <svg class="w-5 h-5 text-blue flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0L6.343 16.657a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span class="text-sm text-slate-600">Mogadishu, Somalia</span>
                </div>
                <!-- Email -->
                <div class="flex gap-3 items-start">
                  <svg class="w-5 h-5 text-blue flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <a href="mailto:info@somvision.org" class="text-sm text-blue hover:underline">info@somvision.org</a>
                </div>
                <!-- Phone -->
                <div class="flex gap-3 items-start">
                  <svg class="w-5 h-5 text-blue flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="text-sm text-slate-600">+252 612 657 171</span>
                </div>
                <!-- Hours -->
                <div class="flex gap-3 items-start">
                  <svg class="w-5 h-5 text-blue flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-sm text-slate-600">Sunday to Thursday, 8:00 AM to 5:00 PM (EAT)</span>
                </div>
              </div>
            </div>

            <!-- Quick Contact Options -->
            <div class="bg-slate-50 rounded-lg p-6 border border-slate-200">
              <h3 class="font-semibold text-navy mb-4">Quick Contact Options</h3>
              <ul class="space-y-3">
                <li class="flex items-center gap-2 text-sm text-slate-600">
                  <span class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></span>
                  Request a proposal
                </li>
                <li class="flex items-center gap-2 text-sm text-slate-600">
                  <span class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></span>
                  Technical consultation
                </li>
                <li class="flex items-center gap-2 text-sm text-slate-600">
                  <span class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></span>
                  Partnership inquiry
                </li>
              </ul>
            </div>

            <!-- Info Box -->
            <div class="bg-blue/5 rounded-lg p-4 border border-blue/20">
              <p class="text-sm text-slate-700">
                We respond with clarity, timelines, and next steps aligned to your program needs.
              </p>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form');
    const successMsg = document.getElementById('success-message');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.style.display = 'none';
        if (successMsg) successMsg.style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    const fileInput = document.getElementById('tor-upload');
    const fileLabel = document.getElementById('file-label');
    if (fileInput && fileLabel) {
      fileInput.addEventListener('change', () => {
        if (fileInput.files && fileInput.files.length > 0) {
          fileLabel.textContent = fileInput.files[0].name;
        } else {
          fileLabel.textContent = 'Choose file (PDF, DOC, DOCX, TXT)';
        }
      });
    }
  </script>

</Base>
