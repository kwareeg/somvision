---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import CTABand from '../../components/CTABand.astro';

/* ── Team data ─────────────────────────────────────────────────── */

const executives = [
  {
    name: "Dr. Abdijabar Hassan Dini",
    role: "Chief Executive Officer (CEO)",
    bio: "Dr. Abdijabar brings over 32 years of experience in social development, combining academic depth with senior field leadership. He has lectured and conducted research at the Somali National University's Faculty of Veterinary Medicine, and has worked with the IAEA, CARE International, and UNICEF across South Africa, Afghanistan, Iraq, Syria, Yemen, and Somalia. Dr. Dini champions community-driven strategies for sustainable development and gender equity, drawing on strong management and leadership skills to empower communities for lasting change.",
    photo: "/team/dr-diini.jpeg",
  },
  {
    name: "Abdulrahman Mohamed",
    role: "Country Director, Somalia",
    bio: "A social entrepreneur and public sector leader with over a decade of experience spanning governance, innovation, education, and humanitarian response. Known for driving institutional reforms, delivering multi-donor programmes, and building partnerships across governments, donors, and communities.",
    photo: "/team/abdulrahman-mohamed.jpg",
  },
  {
    name: "Ibrahim Ahmed Mohamed",
    role: "Director of Business Development & Partnerships",
    bio: "Over 20 years of experience in business, government, and institution-building in Somalia. Has served as Technical Advisor in the Office of the Prime Minister and Deputy Head of Mission at the Somali Embassy in Nairobi, bringing strong diplomatic, representational, and private-sector networks.",
    photo: "/team/ibrahim-ahmed.jpg",
  },
];

const directors = [
  {
    name: "Ali Omar Hussein",
    role: "Finance & Administration Director",
    bio: "Ali Omar has more than 28 years of experience with UNICEF, serving as Head of Finance in UNICEF Country Offices in Somalia, Malawi, Nigeria, Afghanistan, Bangladesh, and South Sudan. He was also seconded to UNICEF offices in Rwanda in 1995 and Angola in 1997 and 1998 to support finance operations. Following the 2015 earthquake, Ali undertook a surge mission to the UNICEF office in Nepal, where he supported operations, particularly in administration and finance. Before joining UNICEF, Ali worked with the Office of the Auditor General of Somalia as a Senior Auditor and later served as Chief Accountant at the Mogadishu Milk Factory after completing his studies at American University of Beirut. Ali holds an Executive MBA from BRAC University and a Bachelor of Business Administration (BBA) from the American University of Beirut.",
    photo: "/team/ali-omar.jpg",
  },
  {
    name: "Ilham Ali Mohamed",
    role: "Human Resource Director",
    bio: "Brings management experience spanning Somalia's federal institutions, diplomatic service, and the international development sector, including roles with the Office of the Prime Minister and the Somali Embassy in Kuala Lumpur. Holds an MBA from Westminster University (UK).",
    photo: "/team/ilham-ali.jpg",
  },
  {
    name: "Abass Sheikh",
    role: "Head of Program Delivery & Systems Transformation",
    bio: "A senior operations executive with over 20 years leading humanitarian and development programmes across 15+ fragile and conflict-affected countries. Currently serves as Executive Director of Nexus Consortium Somalia; previously led operations for the USD 75 million USAID-funded GEEL programme.",
    photo: "/team/abass-sheikh.jpg",
  },
];

const consultants = [
  {
    name: "Dr. Abdi-Ilah Abucar Osman",
    role: "Principal Consultant, Global Health & Infectious Diseases",
    bio: "A medical doctor with 40 years of clinical and public health practice across Somalia, Yemen, Libya, South Sudan, Austria, and the UK. Specialises in infectious diseases — tuberculosis, malaria, HIV/AIDS, and visceral leishmaniasis — alongside maternal and child health in underserved settings.",
    photo: "/team/dr-osman.jpeg",
  },
  {
    name: "Dr. Abdullatif Mohamud Abdi",
    role: "Principal Consultant, Livestock Systems",
    bio: "A veterinary scientist and policy expert with four decades of regional experience. Former Somali National Coordinator for PACE and the IGAD Drought Resilience Initiative, and Special Advisor to the Office of the Prime Minister and the Minister of Livestock.",
    photo: "/team/abdullatif-mohamud.jpg",
  },
  {
    name: "Dr. Mohamed Farah Shirdon",
    role: "Principal Consultant, Agricultural Development",
    bio: "A Somali-Canadian agricultural development specialist with over 25 years in agribusiness, value chains, and dryland agriculture across the Middle East and Africa. Former Director General of Somalia's Ministry of Agriculture, with a PhD in Plant Breeding from Cornell University.",
    photo: "/team/dr-shirdon.jpg",
  },
  {
    name: "Dr. Hussein Haji Nur",
    role: "Principal Consultant, Agricultural Policy & Value Chains",
    bio: "A Somali-Canadian agricultural specialist with close to 40 years of experience across Somalia's Ministry of Agriculture, Canada's national breeding programme, and advisory roles in East and Southern Africa. Founder and Executive Director of SATG, with assignments for the World Bank, FAO, USAID, and DFID. PhD in Plant Breeding from the University of Guelph.",
    photo: "/team/dr-hussein-nur.jpg",
  },
  {
    name: "Dr. Hussein Hagi Aden Abdi",
    role: "Senior Consultant, Animal Health & Rural Livelihoods",
    bio: "Over three decades of field experience in animal health, livestock trade, and rural livelihoods across South-Central Somalia, working with Terra Nuova, COOPI, and the Ministry of Livestock, Forestry and Range.",
    photo: "/team/d-hussein-hagi.jpeg",
  },
  {
    name: "Hassan Abdijabar Hassan",
    role: "Legal Advisor, Governance & Humanitarian Affairs",
    bio: "Hassan combines strong legal training with humanitarian exposure and hands-on casework experience. Holding both a Bachelor's degree and a Master's degree in Law, he brings sharp analytical ability to complex legal and factual matters, paired with the professionalism needed to handle them with care. Through his work as a Legal Caseworker and Trainee Solicitor in London, he has developed practical experience reviewing evidence, preparing clear written summaries, and supporting individuals through sensitive and complex cases. His earlier service with the United Nations further sharpened his capabilities in research, coordination, data analysis, reporting, and stakeholder engagement within an international humanitarian setting.",
    photo: "/team/hassan-lawyer.jpeg",
  },
];

/** Generate initials from a name */
function getInitials(name: string): string {
  return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
}

/** Pick a deterministic colour class from the name */
function getColor(name: string): string {
  const palette = ['bg-navy', 'bg-blue', 'bg-teal', 'bg-navy-light'];
  const hash = name.charCodeAt(0) + name.charCodeAt(name.length - 1);
  return palette[hash % palette.length];
}
---

<Base
  title="Our Team | SOMVISION"
  description="Meet the SOMVISION leadership team — senior professionals with deep regional expertise built for practical delivery."
>

  <PageHero
    title="Our Team"
    subtitle="A multidisciplinary team with deep regional expertise, built for practical delivery and lasting institutional impact."
  />

  <!-- ═══════ Intro + Stats ═══════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="max-w-3xl">
        <p class="uppercase text-xs font-bold tracking-widest text-blue mb-3">Who We Are</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy">Senior professionals, grounded in context</h2>
        <p class="text-slate-600 mt-4">
          SOMVISION brings together experienced leaders from across government, the United Nations system, international development, and the private sector. Our team combines decades of institutional knowledge with on-the-ground delivery experience in Somalia and the Horn of Africa.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12">
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-navy">200+</p>
          <p class="text-sm text-slate-500 mt-1">Combined years of experience</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-navy">15+</p>
          <p class="text-sm text-slate-500 mt-1">Countries of operation</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-navy">6</p>
          <p class="text-sm text-slate-500 mt-1">Sector specialisations</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-navy">12</p>
          <p class="text-sm text-slate-500 mt-1">Senior team members</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Executive Leadership ═══════ -->
  <section class="bg-slate-50 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <SectionIntro label="Executive Leadership" title="Setting direction and strategy" centered />

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-12">
        {executives.map((m) => (
          <div class="bg-white rounded-lg border border-slate-200 p-8 hover:shadow-lg transition-all duration-300 relative overflow-hidden group">
            {/* Accent top border */}
            <div class="absolute top-0 left-0 right-0 h-1 bg-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

            <div class="flex flex-col items-center text-center gap-5">
              {m.photo ? (
                <img
                  src={m.photo}
                  alt={m.name}
                  class="w-32 h-32 rounded-full object-cover ring-4 ring-slate-100 group-hover:ring-teal/20 transition-all duration-300"
                  loading="lazy"
                />
              ) : (
                <div class:list={[
                  "w-32 h-32 rounded-full flex items-center justify-center text-white text-3xl font-bold ring-4 ring-slate-100 group-hover:ring-teal/20 transition-all duration-300",
                  getColor(m.name),
                ]}>
                  {getInitials(m.name)}
                </div>
              )}
              <div>
                <h3 class="text-xl font-bold text-navy">{m.name}</h3>
                <p class="text-sm font-semibold text-blue mt-1">{m.role}</p>
                <p class="text-sm text-slate-600 mt-3 leading-relaxed">{m.bio}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ Directors ═══════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <SectionIntro label="Directors" title="Driving operations, finance, and programme delivery" centered />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        {directors.map((m) => (
          <div class="bg-white rounded-lg border border-slate-200 p-6 text-center hover:shadow-lg transition-all duration-300 group relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1 bg-blue transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
            {m.photo ? (
              <img
                src={m.photo}
                alt={m.name}
                class="w-24 h-24 rounded-full object-cover ring-3 ring-slate-100 group-hover:ring-blue/20 mx-auto transition-all duration-300"
                loading="lazy"
              />
            ) : (
              <div class:list={[
                "w-24 h-24 rounded-full flex items-center justify-center text-white text-xl font-bold mx-auto ring-3 ring-slate-100 group-hover:ring-blue/20 transition-all duration-300",
                getColor(m.name),
              ]}>
                {getInitials(m.name)}
              </div>
            )}
            <h3 class="text-lg font-bold text-navy mt-4">{m.name}</h3>
            <p class="text-sm font-semibold text-blue mt-1">{m.role}</p>
            <p class="text-xs text-slate-600 mt-3 leading-relaxed">{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ Principal Consultants & Senior Advisors ═══════ -->
  <section class="bg-slate-50 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <SectionIntro
        label="Principal Consultants & Senior Advisors"
        title="Deep sector expertise across health, agriculture, livestock, and food systems"
        centered
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
        {consultants.map((m) => (
          <div class="bg-white rounded-lg border border-slate-200 p-6 hover:shadow-lg transition-all duration-300 group relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1 bg-navy transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
            <div class="flex items-start gap-5">
              {m.photo ? (
                <img
                  src={m.photo}
                  alt={m.name}
                  class="w-20 h-20 rounded-full object-cover ring-3 ring-slate-100 group-hover:ring-navy/20 flex-shrink-0 transition-all duration-300"
                  loading="lazy"
                />
              ) : (
                <div class:list={[
                  "w-20 h-20 rounded-full flex items-center justify-center text-white text-lg font-bold flex-shrink-0 ring-3 ring-slate-100 group-hover:ring-navy/20 transition-all duration-300",
                  getColor(m.name),
                ]}>
                  {getInitials(m.name)}
                </div>
              )}
              <div>
                <h3 class="text-lg font-bold text-navy">{m.name}</h3>
                <p class="text-sm font-semibold text-blue mt-1">{m.role}</p>
                <p class="text-xs text-slate-600 mt-2 leading-relaxed">{m.bio}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ How We Staff ═══════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 fade-up">
      <div class="max-w-3xl mx-auto text-center">
        <p class="uppercase text-xs font-bold tracking-widest text-blue mb-3">How We Staff</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy">Small teams, clear accountability</h2>
        <p class="text-slate-600 mt-4">
          We deploy compact, accountable teams with technical leadership, delivery coordination, and MEL and data support. This ensures focused execution, clear lines of responsibility, and adaptive learning throughout every engagement.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        <div class="bg-slate-50 rounded-lg p-6 border border-slate-200 hover:border-teal/40 transition-colors duration-300">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
          </div>
          <h3 class="font-semibold text-navy">Technical Leadership</h3>
          <p class="text-sm text-slate-600 mt-2">Senior sector experts who set quality standards and guide methodology.</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-6 border border-slate-200 hover:border-blue/40 transition-colors duration-300">
          <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-semibold text-navy">Delivery Coordination</h3>
          <p class="text-sm text-slate-600 mt-2">Operations leads who keep workstreams on track, on time, and on budget.</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-6 border border-slate-200 hover:border-navy/40 transition-colors duration-300">
          <div class="w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="font-semibold text-navy">MEL & Data Support</h3>
          <p class="text-sm text-slate-600 mt-2">Monitoring, evaluation, and data specialists embedded in every programme.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CTA ═══════ -->
  <CTABand
    title="Want to work with our team?"
    description="Get in touch to discuss how SOMVISION can support your programme goals."
    primaryLabel="Start a Conversation"
    primaryHref="/contact"
  />

</Base>
